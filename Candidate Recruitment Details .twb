      <table>
        <view>
          <datasources>
            <datasource caption='Aegis Candidates' name='sqlproxy.1h776nu17bqfv21fgzwo31el5dya' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Start Date' datatype='date' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='#2025-04-01#'>
              <calculation class='tableau' formula='#2025-04-01#' />
              <range min='#2024-01-01#' />
            </column>
            <column caption='End Date' datatype='date' name='[Parameter 2]' param-domain-type='any' role='measure' type='quantitative' value='#2026-04-27#'>
              <calculation class='tableau' formula='#2026-04-27#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.1h776nu17bqfv21fgzwo31el5dya'>
            <column caption='Candidate Country' datatype='string' name='[Calculation_1349714405203968]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
              <calculation class='tableau' formula='IF [candidateworkcountry] = &quot;&quot; THEN NULL&#13;&#10;ELSEIF [candidateworkcountry] = &quot;India&quot; THEN &quot;INDIA&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;Unitedstate&quot; THEN &quot;United States&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;United state&quot; THEN &quot;United States&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;USA&quot; THEN &quot;United States&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;Unitedkingdom&quot; THEN &quot;United Kingdom&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;United kingdom&quot; THEN &quot;United Kingdom&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;UK&quot; THEN &quot;United Kingdom&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;UAE&quot; THEN &quot;United Arab Emirates&quot;&#13;&#10;ELSEIF [candidateworkcountry] = &quot;Unitedarab&quot; THEN &quot;United Arab Emirates&quot;&#13;&#10;ELSE TRIM(SPLIT([candidateworkcountry], &quot;,&quot;, -1))&#13;&#10;END' />
            </column>
            <column caption='InboundSource' datatype='string' name='[Calculation_1349714412871681]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [inboundsource] = &quot;register&quot; then &quot;Register&quot;&#13;&#10;ELSEIF [inboundsource] = &quot;&apos;register&apos;&quot; THEN &quot;Register&quot;&#13;&#10;ELSEIF  [inboundsource] = &quot;google&quot; THEN &quot;Google&quot;&#13;&#10;ELSEIF [inboundsource] = &quot;linkedin&quot; THEN &quot;LinkedIn&quot;&#13;&#10;ELSE NULL&#13;&#10;END' />
            </column>
            <column caption='Date/Time Filter' datatype='boolean' name='[Calculation_1414799184896000]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='if [candidatecreatedon] &gt;= [Parameters].[Parameter 1] and&#13;&#10;[candidatecreatedon] &lt;= [Parameters].[Parameter 2] then TRUE&#13;&#10;else FALSE&#13;&#10;END' />
            </column>
            <column caption='cvpresent candidates' datatype='integer' name='[Calculation_1718874462052353]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [cvpresent] = &quot;cvpresent&quot; then [candidateid] END' />
            </column>
            <column caption='% of cvpresent candidates' datatype='real' name='[Calculation_1718874463907842]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Calculation_1718874462052353])/COUNTD([candidateid])' />
